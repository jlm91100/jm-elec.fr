{
  "redirects": [
    {
      "source": "/installation-remplacement-declairage",
      "destination": "/services/eclairage-interieur-exterieur",
      "permanent": true
    },
    {
      "source": "/installation-remplacement-declairage/",
      "destination": "/services/eclairage-interieur-exterieur",
      "permanent": true
    },
    {
      "source": "/wp-content/:path*",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
